{
	"version": "2.0.0",
	"tasks": [
    {
      "type": "shell",
      "label": "Database :: Start",
      "detail": "Starts the database",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "docker-compose.yml",
        "-f",
        "docker-compose.dev.yml",
        "up",
        "-d",
        "database"
      ],
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "icon": {
        "id": "database",
        "color": "terminal.ansiBlue"
      },
      "problemMatcher": [],
      "isBackground": true,
    },
    {
      "type": "shell",
      "label": "Database :: Migrate",
      "detail": "Start migration container",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "docker-compose.yml",
        "-f",
        "docker-compose.dev.yml",
        "up",
        "database-bootstrap"
      ],
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "icon": {
        "id": "arrow-circle-right",
        "color": "terminal.ansiGreen"
      },
      "problemMatcher": [],
      "dependsOn": [
        "Database :: Start"
      ],
    }
  ]
}
